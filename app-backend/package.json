{
  "name": "ultimate-ai-assistant-backend",
  "version": "1.0.0",
  "description": "Backend for Ultimate AI Assistant - The most powerful AI automation system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "load-skills": "tsx src/load-skills.ts",
    "stats": "tsx -e \"import { getSkillStatistics } from './src/loaders/SkillLoader'; getSkillStatistics();\""

  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "socket.io": "^4.8.3",
    "mongoose": "^9.3.0",
    "jsonwebtoken": "^9.0.3",
    "bcryptjs": "^3.0.3",
    "express-rate-limit": "^8.3.1",
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.0",
    "zod": "^4.3.6",
    "marked": "^17.0.4",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
